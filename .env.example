# 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# Copy this file to .env and fill in actual values

# ==================== Tushare 配置 ====================
# Tushare API Token (从 https://tushare.pro 获取)
# Get your token from https://tushare.pro
TUSHARE_TOKEN=f4e2b48672fa4e9e8339957001822864abfa596da7ea2d5a41fc2c1c

# ==================== 数据库配置 ====================
# SQLite 数据库路径 / SQLite Database Path (已弃用，建议使用 MySQL)
# DATABASE_URL=sqlite:///data/stock_analysis.db

# MySQL 数据库配置 / MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=stock_analysis

# ==================== 缓存配置 ====================
# 数据缓存目录 / Data Cache Directory
CACHE_DIR=data/cache

# 缓存有效期（秒） / Cache TTL in seconds
CACHE_TTL=86400

# ==================== qlib 配置 ====================
# qlib 数据目录 / qlib Data Directory
QLIB_DATA_PATH=data/qlib_data

# qlib 配置文件路径 / qlib Config File Path
QLIB_CONFIG_PATH=config/qlib_config.yaml

# ==================== 模型配置 ====================
# 默认预测模型 / Default Prediction Model
DEFAULT_MODEL=lightgbm

# 模型保存目录 / Model Save Directory
MODEL_DIR=models/saved

# ==================== 日志配置 ====================
# 日志级别 / Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件路径 / Log File Path
LOG_FILE=logs/stock_analysis.log

# ==================== 交易配置 ====================
# 模拟交易初始资金 / Paper Trading Initial Capital
INITIAL_CAPITAL=1000000

# 手续费率 / Commission Rate
COMMISSION_RATE=0.0003

# 印花税率 / Stamp Duty Rate (仅卖出收取 / Only charged on selling)
STAMP_DUTY_RATE=0.001

# ==================== Web 界面配置 ====================
# Streamlit 服务端口 / Streamlit Server Port
STREAMLIT_SERVER_PORT=8501

# 主题颜色 / Theme Color
THEME_COLOR=#1f77b4